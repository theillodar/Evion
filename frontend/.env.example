NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_URL=http://localhost:1337

# Create this token in Strapi: Settings -> API Tokens.
# It should allow product/brand/category read-write and upload actions for the custom admin panel.
STRAPI_API_TOKEN=

# Replace all admin defaults before deploying to Vercel.
ADMIN_PANEL_EMAIL=admin@example.com
ADMIN_PANEL_PASSWORD=change-this-password
ADMIN_AUTH_SECRET=change-this-long-random-secret
